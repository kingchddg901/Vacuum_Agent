  "base_station": {
    "action_available": "Action available",
    "action_dry_mop": "Dry Mop",  // dock button: start air-drying the mop pad (not 'dry-mopping' the floor)
    "action_empty_dust": "Empty Dust",  // dock button: empty the dust bin into the dock (Empty = verb)
    "action_stop_drying": "Stop Drying",  // dock button: stop the mop air-dry cycle
    "action_unavailable": "Action unavailable",
    "action_wash_mop": "Wash Mop",  // dock button: wash the mop pad at the dock (not 'mop with wash water')
    "activity_dry_start": "Dry Start",  // dock activity: mop air-drying cycle started, not a clean/run start
    "activity_dust_empty": "Dust Empty",  // dock activity event label: a dust-empty happened (noun pair, not 'dust is empty')
    "activity_mop_wash": "Mop Wash",  // dock activity event label: a mop-wash happened (reversed noun order)
    "activity_subtitle": "Last known dock service activity",
    "activity_title": "Recent Dock Activity",
    "dock_actions_subtitle": "Backend-gated dock controls",  // subtitle: dock controls shown/hidden per backend capability ('Backend-gated' = gated by support)
    "dock_actions_title": "Dock Actions",
    "minutes_short": "{minutes} min",
    "no_activity_yet": "No activity yet",
    "pause_timeout_subtitle": "Default pause timeout used when a run is paused",
    "pause_timeout_title": "Pause Timeout",
    "recorded_count": {"other":"{count} recorded"},  // plural; activity-card detail: count of recorded events of this kind, e.g. '5 recorded'
    "stat_after_job": "After Job",  // stat label: projected tank level remaining after the queued job
    "stat_dock_status": "Dock Status",
    "stat_docked": "Docked",  // stat label asking 'is the robot docked?' (value = Yes/No), not a status word
    "stat_job_use": "Job Use",  // stat label: clean-water this job is projected to use (ml)
    "stat_lifecycle": "Lifecycle",  // stat label: dock lifecycle state (drying/washing/idle), not product lifespan
    "stat_station_water": "Station Water",
    "stat_tank_now": "Tank Now",  // stat label: clean-water tank volume right now (water tank, in ml)
    "stat_task": "Task",  // stat label: robot's current task status string from the device
    "state_ready": "Ready",
    "state_running": "Running...",  // dock-action button state while the action is sending, not robot 'cleaning'
    "state_unavailable": "Unavailable",
    "station_status_subtitle": "Dock, lifecycle, and robot task state",
    "station_status_title": "Station Status",
    "unknown": "Unknown",
    "updated_prefix": "Updated {timestamp}",
    "water_subtitle": "Current dock water plus projected post-job tank level",
    "water_title": "Water"  // Water panel section heading (dock water tank levels), not a per-room water setting
  },
