    "empty_app_generic": "your robot's app",  // Fragment inserted into 'empty' as {appPhrase} when brand unknown: 'your robot's app'.
    "first_room": "First room",  // marks the first segment (no merge-up control); start of the run
    "keep_anyway": "Keep anyway",
    "merge_up": "Merge up",  // Button. Merges THIS room INTO the one above it (directional term of art).
    "merged_label": "merged",  // boundary toggle state = this cut is merged into the room above
    "merged_label_uncertain": "merged · uncertain",  // boundary state: merged, but the detected cut was low-confidence
    "mode": "Mode",  // field label above clean-mode chips (vacuum/mop/both); the cleaning mode, NOT theme appearance mode
    "mode_mop": "Mop",  // clean-mode chip value: mop-only
    "mode_vacuum": "Vacuum",  // clean-mode chip value: vacuum-only (no mopping)
    "mode_vacuum_mop": "Vac & Mop",  // clean-mode chip value: vacuum + mop together (short 'Vac & Mop')
    "next_name_rooms": "Next: name rooms",
    "passes": "Passes",  // field label for cleaning-pass count chips (1x / 2x)
    "pick_another_room": "… pick another room",
    "review": "Review",  // button on a pending app-started run that opens the review wizard
    "room_n": "Room {n}",
    "rooms_label": "Rooms",  // label for the room-COUNT stepper (how many rooms); a number, not a list of rooms
    "seg_n": "seg {n}",  // 'seg {n}' = abbreviated segment label (legacy step 1); n is the detected-segment order
    "segments_merged": {"other":"{count} segments merged"},  // plural
    "setting_cleaning_path": "Cleaning Path",  // clean-intensity setting row (maps to clean_intensity), labelled 'Cleaning Path'
    "setting_suction": "Suction",  // per-room suction/fan-speed LEVEL setting row
    "setting_water": "Water",  // per-room mop water-LEVEL setting row (low/med/high), only shown for mop modes
    "split_here": "Split here",  // Button: reopens a detected cut, splitting this room into a new room at this point.
