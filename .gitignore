harness/dist/
harness/out/
test-results/
playwright-report/

# MkDocs docs-site build output (built in CI; never committed — docs/ is the source)
/site/
/site-docs/

# HA user data (never commit)
*.storage
.storage/

# OS
.DS_Store
Thumbs.db
desktop.ini

# IDE
.vscode/
.idea/
*.swp
*.swo

# Staging / dev artifacts
mapping_staging/

# Auto-generated at HA startup by __init__.py — not a source file
custom_components/eufy_vacuum/frontend/animal-svg/animals/index.json

# Commit-message scratch files (used by `git commit -F` for long messages)
.commit_msg*
*.commit_msg
COMMIT_MSG*

# Local backup archives
*.zip

# Claude Code settings
.claude/

# Docker cold-install harness — persistent HA config from docker-compose.yml.
# Wipe the folder to test a fresh-from-zero install.
.test-config/
